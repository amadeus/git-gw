{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "typescript/no-useless-default-assignment": "off"
  },
  "overrides": [
    {
      "files": ["src/**/*.ts", "test/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.{1,2}/)",
                "message": "Use the @/ alias instead of relative imports."
              }
            ]
          }
        ]
      }
    }
  ]
}
