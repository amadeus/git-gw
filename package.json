{
  "name": "@amadeusdemarzi/git-gw",
  "version": "1.0.2",
  "description": "Opinionated CLI for branch-like Git worktree workflows",
  "keywords": [
    "cli",
    "git",
    "git-worktree",
    "worktree"
  ],
  "homepage": "https://github.com/amadeus/git-gw#readme",
  "bugs": {
    "url": "https://github.com/amadeus/git-gw/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amadeus/git-gw.git"
  },
  "bin": {
    "gw": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "tsup",
    "prepare": "tsup",
    "format": "bun run imports:fix && oxfmt . --write",
    "format:check": "oxfmt . --check",
    "imports:fix": "bun run scripts/fix-relative-imports.ts",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "pack:smoke": "bun run scripts/pack-smoke.ts"
  },
  "dependencies": {
    "commander": "14.0.3",
    "enquirer": "2.4.1",
    "execa": "9.6.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "bun@1.3.6"
}
