{
  "name": "git-gw",
  "version": "0.1.0",
  "description": "Git worktree project helper CLI",
  "license": "MIT",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "bin": {
    "gw": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "git",
    "worktree",
    "cli"
  ],
  "dependencies": {
    "commander": "14.0.3",
    "enquirer": "2.4.1",
    "execa": "9.6.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
